# cc-studio サーバ・プロビジョニングの調整値。
# このファイルを cc-studio.env（gitignore 済み）にコピーして編集するか、
# 同名の環境変数で setup.sh に渡す。未設定なら下記の既定が使われる。

# code-server がバインドするポート（前段の tailscale serve の転送先と一致させる）
CC_PORT=8088

# バインドアドレス。HTTPS は前段の tailscale serve に任せるので loopback 既定。
# tailnet から直接叩かせたい場合のみ 0.0.0.0 等にする。
CC_BIND=127.0.0.1

# 起動時に開く既定フォルダ
CC_FOLDER=$HOME

# code-server の User 設定ディレクトリ（settings.json の置き場）
CC_USER_DIR=$HOME/.local/share/code-server/User

# code-server standalone install の prefix（バイナリは $CC_PREFIX/bin/code-server）
CC_PREFIX=$HOME/.local

# notify-relay（通知中継）がバインドするポート
# （install-notify.sh の systemd unit / tailscale serve --set-path /cc-notify の転送先と一致させる）
CC_NOTIFY_RELAY_PORT=8770
